# Baseline security headers applied site-wide. CSP starts in report-only so
# nothing is blocked yet — review browser console / report-uri output for
# violations, then promote `Content-Security-Policy-Report-Only` to
# `Content-Security-Policy` once the policy fits the site.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Content-Security-Policy-Report-Only: default-src 'self' https://emwiki.com; script-src 'self' https://emwiki.com https://cdn.jsdelivr.net 'unsafe-inline' 'unsafe-eval'; style-src 'self' https://emwiki.com 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob: https:; frame-src https://iframe.videodelivery.net https://*.cloudflarestream.com; connect-src 'self' https://emwiki.com https://*.cloudflarestream.com https://videodelivery.net; font-src 'self' https://emwiki.com data:; base-uri 'self'; form-action 'self'; frame-ancestors 'self'

# /secure/page is stricter than the baseline.
/secure/page
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer

/static/*
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet

https://emwikirr.pages.dev/*
  X-Robots-Tag: noindex

# Cache the root page for 1 hour
/
  Cache-Control: no-cache, no-store, must-revalidate

# Cache HTML for only 1 hour
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Short-lived cache with revalidation for CSS/JS.
# 5-minute browser cache; the must-revalidate forces a fresh check on the next
# navigation so a deploy can't leave clients stuck on stale assets for long.
# Once you adopt hashed filenames, swap to `public, max-age=31536000, immutable`.
/*.css
  Cache-Control: public, max-age=300, must-revalidate

/*.js
  Cache-Control: public, max-age=300, must-revalidate

# Cache images for 1 month
/*.jpg
  Cache-Control: public, max-age=2592000, immutable

/*.png
  Cache-Control: public, max-age=2592000, immutable

/*.webp
  Cache-Control: public, max-age=2592000, immutable